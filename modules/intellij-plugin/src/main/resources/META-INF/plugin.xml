<idea-plugin>
    <id>io.princeofspace.intellij</id>
    <name>Prince of Space</name>
    <vendor url="https://github.com/prince-of-space/prince-of-space">prince-of-space</vendor>
    <description><![CDATA[Formats Java sources with the <a href="https://github.com/prince-of-space/prince-of-space">Prince of Space</a> formatter. Configure all formatter options under <b>Settings → Tools → Prince of Space</b>; use <b>Code → Reformat with Prince of Space…</b> or enable format on save.]]></description>
    <change-notes><![CDATA[Initial release: format current editor from IntelliJ language level.]]></change-notes>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="io.princeofspace.intellij.PrinceOfSpaceProjectSettings"/>
        <projectConfigurable
                parentId="tools"
                instance="io.princeofspace.intellij.PrinceOfSpaceConfigurable"
                id="PrinceOfSpace.Configurable"
                displayName="Prince of Space"/>
    </extensions>

    <applicationListeners>
        <listener class="io.princeofspace.intellij.PrinceOfSpaceFormatOnSaveListener"
                  topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
    </applicationListeners>

    <actions>
        <action
                id="PrinceOfSpace.FormatEditor"
                class="io.princeofspace.intellij.PrinceFormatAction"
                text="Reformat with Prince of Space..."
                description="Format the current Java file using the Prince of Space formatter">
            <add-to-group group-id="CodeMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
